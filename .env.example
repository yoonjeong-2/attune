# 이 파일을 복사해 .env 를 만들고 값을 채우세요:  cp .env.example .env
# .env 는 git에 올라가지 않습니다(.gitignore). 키를 코드에 하드코딩하지 마세요(CLAUDE.md §8·§12).

# 필수 — Claude API 키 (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=

# 선택 — 분석 모델. 기본값은 최신 Opus. 비용/속도를 낮추려면 claude-sonnet-5 등으로 변경.
# ANTHROPIC_MODEL=claude-opus-4-8

# 선택 — 목업 모드. true면 실제 API를 호출하지 않고 가짜 결과 반환 (API 비용 0, UI 개발용).
# USE_MOCK=false
# 목업 기본 직군 (개발 | 기획). 입력에 '개발'/'기획' 글자를 넣으면 그때그때 전환됨.
# MOCK_DOMAIN=개발
# 목업 기본 케이스 (높음 | 보통 | 낮음). 입력에 해당 글자를 넣으면 그때그때 전환됨.
# MOCK_CASE=보통

# 선택 — 얇은 서버 포트 (Vite dev 프록시 대상과 일치해야 함, 기본 8787)
# PORT=8787
